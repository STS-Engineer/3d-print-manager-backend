# Server
PORT=5000
NODE_ENV=production

# PostgreSQL Database
DB_HOST=avo-adb-002.postgres.database.azure.com
DB_PORT=5432
DB_NAME=print3d_manager
DB_USER=administrationSTS
DB_PASSWORD=St$@0987
