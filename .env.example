# Server
PORT=5000
NODE_ENV=development

# PostgreSQL Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=print3d_manager
DB_USER=postgres
DB_PASSWORD=your_password_here

# PostgreSQL connection pool and session safeguards
# Max database connections opened by this Node.js instance
DB_POOL_MAX=15
# How long an unused pooled connection can stay idle before being closed (ms)
DB_IDLE_TIMEOUT_MS=30000
# How long to wait when opening a new database connection (ms)
DB_CONNECTION_TIMEOUT_MS=10000
# Max duration allowed for a SQL statement before PostgreSQL cancels it (ms)
DB_STATEMENT_TIMEOUT_MS=120000
# Max duration allowed while waiting on a database lock (ms)
DB_LOCK_TIMEOUT_MS=10000
# Max duration allowed for sessions left idle inside an open transaction (ms)
DB_IDLE_IN_TX_TIMEOUT_MS=60000
# Name shown in pg_stat_activity.application_name for easier source tracing
DB_APPLICATION_NAME=3d-print-manager-local

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=24h

# File uploads
UPLOAD_DIR=uploads
MAX_FILE_SIZE=52428800

# Email (optional - for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@avocarbon.com
SMTP_PASS=your_email_password
# SMTP_PASSWORD is also supported as an alias for SMTP_PASS
EMAIL_FROM=3dprint@avocarbon.com
# SMTP_FROM is also supported as an alias for EMAIL_FROM

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
