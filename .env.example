# Server
PORT=5000
NODE_ENV=development

# PostgreSQL Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=print3d_manager
DB_USER=postgres
DB_PASSWORD=your_password_here

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=24h

# File uploads
UPLOAD_DIR=uploads
MAX_FILE_SIZE=52428800

# Email (optional - for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@avocarbon.com
SMTP_PASS=your_email_password
# SMTP_PASSWORD is also supported as an alias for SMTP_PASS
EMAIL_FROM=3dprint@avocarbon.com
# SMTP_FROM is also supported as an alias for EMAIL_FROM

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
